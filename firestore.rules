rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isFacilityOwner(userId) {
      return isSignedIn() && userId is string && request.auth.uid == userId;
    }

    function hasValidLocation(location) {
      return location is map
        && location.lat is number
        && location.lng is number;
    }

    function hasValidRoomTypes(roomTypes) {
      return roomTypes is list
        && roomTypes.size() > 0
        && roomTypes.size() <= 12;
    }

    function hasValidStatus(status) {
      return status in ['available', 'fewBeds', 'full'];
    }

    function hasCoordinatesIfPresent(data) {
      return !data.keys().hasAny(['coordinates']) || hasValidLocation(data.coordinates);
    }

    function hasValidHospitalPayload(data) {
      return data.keys().hasAll([
          'name',
          'category',
          'description',
          'location',
          'landmark',
          'address',
          'area',
          'contactNumber',
          'website',
          'totalRooms',
          'availableRooms',
          'roomTypes',
          'status',
          'sourceLabel',
          'updatedAt'
        ])
        && data.keys().hasOnly([
          'name',
          'category',
          'description',
          'location',
          'coordinates',
          'landmark',
          'address',
          'area',
          'contactNumber',
          'website',
          'totalRooms',
          'availableRooms',
          'roomTypes',
          'status',
          'sourceLabel',
          'createdAt',
          'updatedAt'
        ])
        && data.name is string
        && data.name.size() > 2
        && data.category is string
        && data.category.size() > 1
        && data.description is string
        && data.description.size() > 10
        && data.landmark is string
        && data.address is string
        && data.address.size() > 5
        && data.area is string
        && data.area.size() > 1
        && data.contactNumber is string
        && data.contactNumber.size() > 6
        && data.website is string
        && data.sourceLabel is string
        && data.sourceLabel.size() > 2
        && data.totalRooms is int
        && data.totalRooms > 0
        && data.availableRooms is int
        && data.availableRooms >= 0
        && data.availableRooms <= data.totalRooms
        && hasValidLocation(data.location)
        && hasCoordinatesIfPresent(data)
        && hasValidRoomTypes(data.roomTypes)
        && hasValidStatus(data.status)
        && data.updatedAt is timestamp;
    }

    function hasValidFacilityOwnership(data) {
      return data.ownerUserId is string
        && data.ownerUserId.size() > 5
        && data.ownerDisplayName is string
        && data.ownerDisplayName.size() > 1;
    }

    function hasValidFacilityDeletionState(data) {
      return !data.keys().hasAny(['deletedAt', 'deletedByUserId'])
        || (
          isSignedIn()
          && data.deletedAt is timestamp
          && data.deletedByUserId is string
          && data.deletedByUserId == request.auth.uid
        );
    }

    function hasValidFacilityPayload(data) {
      return data.keys().hasAll([
          'name',
          'category',
          'description',
          'location',
          'landmark',
          'address',
          'area',
          'contactNumber',
          'website',
          'totalRooms',
          'availableRooms',
          'roomTypes',
          'status',
          'sourceLabel',
          'ownerUserId',
          'ownerDisplayName',
          'updatedAt'
        ])
        && data.keys().hasOnly([
          'name',
          'category',
          'description',
          'location',
          'coordinates',
          'landmark',
          'address',
          'area',
          'contactNumber',
          'website',
          'totalRooms',
          'availableRooms',
          'roomTypes',
          'status',
          'sourceLabel',
          'ownerUserId',
          'ownerDisplayName',
          'createdAt',
          'updatedAt',
          'deletedAt',
          'deletedByUserId'
        ])
        && hasValidHospitalPayload(data)
        && hasValidFacilityOwnership(data)
        && hasValidFacilityDeletionState(data);
    }

    function isValidFacilityCreate(data) {
      return hasValidFacilityPayload(data)
        && isFacilityOwner(data.ownerUserId)
        && data.createdAt is timestamp
        && !data.keys().hasAny(['deletedAt', 'deletedByUserId']);
    }

    function isValidFacilityUpdate(data) {
      return hasValidFacilityPayload(data)
        && isFacilityOwner(resource.data.ownerUserId)
        && isFacilityOwner(data.ownerUserId)
        && data.createdAt == resource.data.createdAt
        && data.ownerUserId == resource.data.ownerUserId
        && data.ownerDisplayName == resource.data.ownerDisplayName;
    }

    match /hospitals/{hospitalId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /facilities/{facilityId} {
      allow read: if true;
      allow create: if isValidFacilityCreate(request.resource.data);
      allow update: if isValidFacilityUpdate(request.resource.data);
      allow delete: if false;
    }

    match /users/{userId} {
      allow read, write: if false;
    }
  }
}